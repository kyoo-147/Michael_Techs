---
import { SITE } from "@/config";
import { DEFAULT_LOCALE, LOCALES, type Locale } from "@/i18n/config";
import { getHtmlLang, getLocalizedPath, stripLocaleFromPathname } from "@/i18n/utils";
import "@/styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  canonicalURL?: string | URL;
  locale?: Locale;
  scrollSmooth?: boolean;
  robots?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = SITE.title,
  description = SITE.description,
  ogImage = `/${SITE.ogImage}`,
  ogType = "website",
  canonicalURL = Astro.url,
  locale = DEFAULT_LOCALE,
  robots = "index, follow, max-image-preview:large",
  structuredData,
} = Astro.props;

const canonical =
  canonicalURL instanceof URL ? canonicalURL.toString() : canonicalURL;
const socialImageURL = new URL(ogImage, Astro.url).toString();
const socialImageAlt = `${SITE.title} - ${SITE.description}`;
const canonicalPath = stripLocaleFromPathname(new URL(canonical).pathname);
const alternateLinks = LOCALES.map(alternateLocale => ({
  hrefLang: getHtmlLang(alternateLocale),
  href: new URL(getLocalizedPath(alternateLocale, canonicalPath), SITE.website).toString(),
}));
const xDefaultURL = new URL(getLocalizedPath(DEFAULT_LOCALE, canonicalPath), SITE.website).toString();
const ogLocale = {
  en: "en_US",
  vi: "vi_VN",
  "zh-cn": "zh_CN",
}[locale];
const ogAlternateLocales = LOCALES.filter(alternateLocale => alternateLocale !== locale).map(
  alternateLocale => ({
    en: "en_US",
    vi: "vi_VN",
    "zh-cn": "zh_CN",
  })[alternateLocale],
);
const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
const structuredDataScripts = structuredDataItems.map(item =>
  JSON.stringify(item).replace(/</g, "\\u003c")
);
---

<!doctype html>
<html lang={getHtmlLang(locale)}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#f3eedf" />
    <meta name="title" content={title} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=mc" />
    <link rel="icon" type="image/png" href="/favicon-512.png?v=mc" />
    <link rel="canonical" href={canonical} />
    {alternateLinks.map(link => <link rel="alternate" hreflang={link.hrefLang} href={link.href} />)}
    <link rel="alternate" hreflang="x-default" href={xDefaultURL} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale} />
    {ogAlternateLocales.map(alternateLocale => <meta property="og:locale:alternate" content={alternateLocale} />)}
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:secure_url" content={socialImageURL} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:url" content={canonical} />
    <meta property="twitter:image" content={socialImageURL} />
    <meta property="twitter:image:alt" content={socialImageAlt} />
    {structuredDataScripts.map(script => <script is:inline type="application/ld+json" set:html={script} />)}
  </head>
  <body>
    <div class="page-frame">
      <slot />
    </div>
  </body>
</html>
