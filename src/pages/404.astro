---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE } from "@/config";
import Layout from "@/layouts/Layout.astro";
---

<Layout title={`404 | ${SITE.title}`} description="Page not found." locale="en">
  <Header locale="en" />
  <main class="site-shell flex min-h-[55vh] items-center justify-center pb-16">
    <div class="text-center">
      <div class="text-[6rem] font-semibold tracking-[-0.06em] text-accent">404</div>
      <p class="mt-2 text-lg text-muted-foreground">The page you are looking for does not exist.</p>
      <a href="/" class="mt-6 inline-flex border-b border-border-strong pb-1 text-sm text-foreground hover:border-accent hover:text-accent">
        Back to home
      </a>
    </div>
  </main>
  <Footer locale="en" />
</Layout>
