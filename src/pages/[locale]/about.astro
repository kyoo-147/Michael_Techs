---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE } from "@/config";
import { NON_DEFAULT_LOCALES } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import Layout from "@/layouts/Layout.astro";
import { getLocalizedFeaturedPosts, getLocalizedFeaturedWork } from "@/utils/content";
import AboutPageContent from "@/components/pages/AboutPageContent.astro";

export async function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map(locale => ({ params: { locale } }));
}

const locale = Astro.params.locale as "vi" | "zh-cn";
const t = useTranslations(locale);
const posts = await getLocalizedFeaturedPosts(locale, 4);
const work = await getLocalizedFeaturedWork(locale, 4);
const aboutDescription =
  locale === "vi"
    ? "Giới thiệu Michael, kỹ sư AI workflow automation tại Việt Nam, xây dựng hệ thống AI thực dụng, computer vision, edge AI và phần mềm vận hành."
    : "关于 Michael：来自越南的 AI workflow automation engineer，构建 practical AI systems、computer vision、edge AI 与业务自动化软件。";
const aboutStructuredData = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: t.about.title,
  description: aboutDescription,
  url: `${SITE.website}${locale}/about`,
  mainEntity: {
    "@type": "Person",
    name: SITE.author,
    url: SITE.website,
    jobTitle: "AI workflow automation engineer",
    sameAs: ["https://github.com/kyoo-147", "https://www.linkedin.com/in/minh-cuong-bui/"],
  },
};
---

<Layout title={`${t.about.title} | AI Workflow Automation Engineer`} description={aboutDescription} locale={locale} structuredData={aboutStructuredData}>
  <Header locale={locale} />
  <main class="site-shell pb-12">
    <AboutPageContent locale={locale} posts={posts} work={work} />
  </main>
  <Footer locale={locale} />
</Layout>
