---
import ContactPage from "@/components/pages/ContactPage.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE } from "@/config";
import { NON_DEFAULT_LOCALES } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import Layout from "@/layouts/Layout.astro";

export async function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map(locale => ({ params: { locale } }));
}

const locale = Astro.params.locale as "vi" | "zh-cn";
const t = useTranslations(locale);
---

<Layout title={`${t.nav.contact} | ${SITE.title}`} description={SITE.description} locale={locale}>
  <Header locale={locale} />
  <main class="site-shell pb-12">
    <ContactPage locale={locale} />
  </main>
  <Footer locale={locale} />
</Layout>
