---
import ContactPage from "@/components/pages/ContactPage.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE } from "@/config";
import { NON_DEFAULT_LOCALES } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import Layout from "@/layouts/Layout.astro";

export async function getStaticPaths() {
  return NON_DEFAULT_LOCALES.map(locale => ({ params: { locale } }));
}

const locale = Astro.params.locale as "vi" | "zh-cn";
const t = useTranslations(locale);
const contactDescription =
  locale === "vi"
    ? "Liên hệ Michael cho hợp tác AI engineering, workflow automation, computer vision, OCR, edge AI, hệ thống sản phẩm và tư vấn kỹ thuật."
    : "联系 Michael，合作 AI engineering、workflow automation、computer vision、OCR、edge AI、产品系统与技术咨询。";
const contactStructuredData = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: t.nav.contact,
  description: contactDescription,
  url: `${SITE.website}${locale}/contact`,
  mainEntity: {
    "@type": "Person",
    name: SITE.author,
    email: "mailto:navinservicesnv000@gmail.com",
    url: SITE.website,
  },
};
---

<Layout title={`${t.nav.contact} | AI Engineering Collaboration`} description={contactDescription} locale={locale} structuredData={contactStructuredData}>
  <Header locale={locale} />
  <main class="site-shell pb-12">
    <ContactPage locale={locale} />
  </main>
  <Footer locale={locale} />
</Layout>
