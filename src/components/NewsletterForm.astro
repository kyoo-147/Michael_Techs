---
export interface Props {
  variant?: "default" | "compact";
}

const { variant = "default" } = Astro.props;
---

<div class={variant === "default" ? "newsletter-box bg-gray-50 dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 rounded-lg p-6 my-8" : "newsletter-compact mt-6"}>
  {variant === "default" && (
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
      Interested in a project, collaboration, or technical discussion?
    </p>
  )}

  <a href="/contact" class="inline-flex px-6 py-2 bg-accent rounded-md hover:bg-accent/90 transition-colors font-medium whitespace-nowrap focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2" style="color: white;">
    Contact Michael
  </a>

  {variant === "default" && (
    <p class="text-xs text-gray-500 dark:text-gray-400 mt-3">
      Email, GitHub, LinkedIn, and X are available on the contact page.
    </p>
  )}
</div>

<style>
  @media (max-width: 640px) {
    .newsletter-box {
      margin-left: -1rem;
      margin-right: -1rem;
      border-radius: 0;
    }
  }
</style>
