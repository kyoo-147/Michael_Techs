---
import type { Locale } from "@/i18n/config";

export interface Props {
  locale?: Locale;
}
---

<footer id="contact" class="site-shell pb-8 pt-12 text-sm text-muted-foreground">
  <div class="site-hairline pt-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <div>&copy; 2026 Michael</div>
      <div>
        <img
          src="/assets/signature-small.webp"
          alt="Michael's Signature"
          class="h-24 w-auto object-contain dark:invert opacity-80"
          loading="lazy"
          decoding="async"
          width="360"
          height="186"
        />
      </div>
    </div>
  </div>
</footer>
